# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in the values.
# The app runs without any of these (public FREE tier, no auth/payments) —
# each block below unlocks a feature.
# ---------------------------------------------------------------------------

# --- Supabase (auth + profiles) --------------------------------------------
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — SERVER ONLY. Used by the Lemon Squeezy webhook AND to
# read/write the persisted standings cache (season_cache table). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Standings refresh endpoint --------------------------------------------
# Secret guarding POST/GET /api/cron/refresh-standings. Set any random string,
# then call the endpoint with `Authorization: Bearer <this>` to seed/refresh.
CRON_SECRET=your-random-secret

# --- Rate limiting (optional) ----------------------------------------------
# Upstash Redis REST for distributed rate limiting on /api/checkout. Without
# these, an in-memory per-instance limiter is used automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- App URL (used to build the checkout redirect) -------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dev only: preview PRO features without a paid account -----------------
# Set to "true" to treat the current session as PRO in development.
# Ignored in production builds. Leave unset for the normal FREE experience.
# NEXT_PUBLIC_FORCE_PRO=true

# --- Lemon Squeezy (payments) ----------------------------------------------
# API key: lemonsqueezy.com → Settings → API.
LEMONSQUEEZY_API_KEY=your-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
# The variant id of your "PRO" product.
LEMONSQUEEZY_PRO_VARIANT_ID=your-variant-id
# Signing secret from the webhook you create (see README).
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
